{
  "name": "alt-text-ai",
  "productName": "Alt Text AI",
  "version": "1.0.0",
  "description": "Generate alt text for images using local vision models via Ollama",
  "main": "src/main/main.js",
  "scripts": {
    "start": "concurrently \"cross-env ELECTRON=true vite dev\" \"wait-on tcp:5173 && electron .\"",
    "dev": "vite",
    "electron:dev": "concurrently \"cross-env ELECTRON=true vite dev\" \"wait-on tcp:5173 && electron .\"",
    "build": "vite build",
    "generate-icons": "node scripts/generate-icons.js",
    "electron:build": "npm run generate-icons && cross-env ELECTRON=true vite build && electron-builder -mwl",
    "electron:build:mac": "npm run generate-icons && cross-env ELECTRON=true vite build && electron-builder --mac --config.mac.identity=null",
    "electron:build:win": "npm run generate-icons && cross-env ELECTRON=true vite build && electron-builder --win",
    "electron:build:linux": "npm run generate-icons && cross-env ELECTRON=true vite build && electron-builder --linux",
    "preview": "vite preview",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.{js,vue,css}'",
    "icons": "./scripts/create-icons.sh",
    "prebuild": "npm run icons"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.23",
    "@heroicons/vue": "^2.2.0",
    "@huggingface/inference": "^2.8.1",
    "@vueuse/core": "^12.2.0",
    "dropzone": "^5.9.3",
    "pinia": "^2.3.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^4.6.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.1",
    "cross-env": "^7.0.3",
    "electron": "^25.9.8",
    "electron-builder": "^25.1.8",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "postcss": "^8.4.49",
    "prettier": "^3.8.1",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.17",
    "vite": "^4.5.5",
    "vite-plugin-electron": "^0.11.2",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.actuallyusefulai.alttextai",
    "productName": "Alt Text AI",
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "src/preload/**/*",
      "assets/icons/*"
    ],
    "directories": {
      "output": "dist_electron",
      "buildResources": "assets"
    },
    "afterSign": "scripts/notarize.js",
    "mac": {
      "icon": "assets/icons/triangle_construct_light.gif",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "darkModeSupport": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "notarize": true,
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "dmg": {
      "sign": false,
      "format": "ULFO",
      "writeUpdateInfo": false,
      "icon": "assets/icons/triangle_construct_light.gif",
      "iconSize": 128,
      "title": "${productName}",
      "backgroundColor": "#f9fafb",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 130,
          "y": 190,
          "type": "file"
        },
        {
          "x": 410,
          "y": 190,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "icon": "build/icons/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "build/icons",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lukeslp/alt-text-local-ai.git"
  },
  "keywords": [
    "alt-text",
    "accessibility",
    "a11y",
    "electron",
    "ollama",
    "vision"
  ],
  "author": {
    "name": "Luke Steuber",
    "email": "luke@lukesteuber.com"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/lukeslp/alt-text-local-ai/issues"
  },
  "homepage": "https://github.com/lukeslp/alt-text-local-ai#readme"
}
